# Copy to .env and fill in your keys (this file is safe to commit; .env is git-ignored).
# BRAVE_API_KEY is always required; provide the key for whichever LLM backend you
# run (--provider gemini, the default, needs GEMINI_API_KEY; --provider deepseek
# needs DEEPSEEK_API_KEY).
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=sk-...
BRAVE_API_KEY=BSA...
